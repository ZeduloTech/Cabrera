VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO not_rosc5
  CLASS BLOCK ;
  FOREIGN not_rosc5 ;
  ORIGIN 0.000 0.000 ;
  SIZE 50.000 BY 50.000 ;
  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal4 ;
        RECT 25.600 11.460 27.200 39.500 ;
    END
    PORT
      LAYER Metal5 ;
        RECT 10.080 27.610 39.760 29.210 ;
    END
  END VDD
  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal4 ;
        RECT 28.900 11.460 30.500 39.500 ;
    END
    PORT
      LAYER Metal5 ;
        RECT 10.080 30.910 39.760 32.510 ;
    END
  END VSS
  PIN rosc_enable
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 1.057000 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 25.760 0.560 26.320 ;
    END
  END rosc_enable
  PIN rosc_out
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 1.102000 ;
    ANTENNADIFFAREA 0.897600 ;
    PORT
      LAYER Metal2 ;
        RECT 24.640 49.440 25.200 50.000 ;
    END
  END rosc_out
  OBS
      LAYER Nwell ;
        RECT 9.650 11.330 40.190 39.630 ;
      LAYER Metal1 ;
        RECT 10.080 11.460 39.760 39.500 ;
      LAYER Metal2 ;
        RECT 18.620 49.140 24.340 49.440 ;
        RECT 25.500 49.140 30.360 49.440 ;
        RECT 18.620 11.570 30.360 49.140 ;
      LAYER Metal3 ;
        RECT 0.560 26.620 30.410 39.340 ;
        RECT 0.860 25.460 30.410 26.620 ;
        RECT 0.560 11.620 30.410 25.460 ;
  END
END not_rosc5
END LIBRARY

